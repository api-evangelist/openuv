          "name": "Get Current UV Index",
          "request": {
            "name": "Get Current UV Index",
            "description": {
              "content": "Returns the current UV index, daily maximum UV, ozone level, sun position\nand Fitzpatrick skin-type-specific safe exposure times for the given coordinate.\n",
              "type": "text/plain"
            },
            "url": {
