          "name": "Get Sun Protection Window",
          "request": {
            "name": "Get Sun Protection Window",
            "description": {
              "content": "Returns the start and end times of the recommended sun-protection window for\nthe day, defined as the period when UV index crosses the configurable `from`\nand `to` thresholds (default 3.5).\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "protection"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "lat",
                  "value": "<float>",
                  "description": "(Required) Latitude in decimal degrees (-90 to 90)."
                },
                {
                  "disabled": false,
                  "key": "lng",
                  "value": "<float>",
                  "description": "(Required) Longitude in decimal degrees (-180 to 180)."
                },
                {
                  "disabled": false,
                  "key": "alt",
                  "value": "<float>",
                  "description": "Altitude in meters above sea level. Improves UV accuracy for high-elevation locations."
                },
                {
                  "disabled": false,
                  "key": "from",
                  "value": "3.5",
                  "description": "Lower UV index bound for the protection window. Defaults to 3.5."
                },
                {
                  "disabled": false,
                  "key": "to",
                  "value": "3.5",
                  "description": "Upper UV index bound for the protection window. Defaults to 3.5."
                }
              ],
              "variable": []
            },
            "header": [
