                "uv"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "lat",
                  "value": "<float>",
                  "description": "(Required) Latitude in decimal degrees (-90 to 90)."
                },
                {
                  "disabled": false,
                  "key": "lng",
                  "value": "<float>",
                  "description": "(Required) Longitude in decimal degrees (-180 to 180)."
                },
                {
                  "disabled": false,
                  "key": "alt",
                  "value": "<float>",
                  "description": "Altitude in meters above sea level. Improves UV accuracy for high-elevation locations."
                },
                {
                  "disabled": false,
                  "key": "dt",
                  "value": "<dateTime>",
                  "description": "ISO 8601 timestamp for the requested UV reading or forecast anchor. Defaults to the current time."
